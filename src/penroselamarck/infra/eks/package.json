{
  "name": "penroselamarck-eks-cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "./scripts/with-env.sh cdk",
    "bootstrap": "./scripts/with-env.sh cdk bootstrap",
    "synth": "./scripts/with-env.sh cdk synth",
    "deploy": "./scripts/with-env.sh cdk deploy",
    "synth:oidc-bootstrap": "./scripts/with-env.sh cdk --app 'npx ts-node --prefer-ts-exts bin/penroselamarck-github-oidc-bootstrap.ts' synth PenroselamarckGithubOidcBootstrapStack",
    "deploy:oidc-bootstrap": "./scripts/with-env.sh cdk --app 'npx ts-node --prefer-ts-exts bin/penroselamarck-github-oidc-bootstrap.ts' deploy PenroselamarckGithubOidcBootstrapStack --require-approval never"
  },
  "dependencies": {
    "@aws-cdk/lambda-layer-kubectl-v29": "^2.1.1",
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
