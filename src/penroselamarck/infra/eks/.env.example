# Copy this file to .env and fill in required values.
# Do not commit .env.

# Required when using temporary/session credentials.
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_SESSION_TOKEN=REPLACE_ME

# Required region for CDK deploy/synth.
AWS_REGION=PASTE_HERE
VPC_ID=PASTE_HERE

# Optional web standalone debug mode for EKS deploy parameter.
# true  -> web serves /v1 locally (no API dependency)
# false -> web proxies /v1 to penroselamarck-api
WEB_STANDALONE_DEBUG=false

# INFO
AWS_ACCOUNT=PASTE_HERE
