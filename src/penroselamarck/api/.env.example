# API identity metadata (optional)
API_TITLE=Penrose-Lamarck MCP (HTTP bridge)
API_VERSION=0.2.0
MCP_SERVER_NAME=penroselamarck-api
MCP_SERVER_VERSION=0.2.0

# API auth behavior (for local testing only)
AUTH_DISABLED=false

# OAuth/Auth0 settings (set when auth is enabled)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=
AUTH0_JWKS_URL=
AUTH0_ALGORITHMS=RS256
AUTH0_ROLES_CLAIM=permissions
AUTH0_CLOCK_SKEW_SECONDS=60
AUTH0_JWKS_CACHE_TTL_SECONDS=600
AUTH0_JWKS_TIMEOUT_SECONDS=5

# MCP OAuth resource metadata (optional overrides)
MCP_RESOURCE_URL=
MCP_OAUTH_SCOPES=

# GitHub integration (optional)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main
GITHUB_API_URL=https://api.github.com
GITHUB_MANIFEST_DIR=docs/sphinx/src/manifest
